<!-- ===== COMMENTS ===== -->
<div id="comments" class="page">
  <nav class="top-nav">
    <button class="nav-back" onclick="goTo('lobby')">← กลับ</button>
    <span class="nav-title">💬 ร้องเรียน / ความคิดเห็น</span>
  </nav>

  <div class="comments-hero">
    <h1>บอกเราได้เลย! 📣</h1>
    <div class="gold-line"></div>
    <p>อยากได้อะไร? ต้องการให้ปรับปรุงอะไร? เราฟังทุกเสียงของน้องๆ</p>
  </div>

  <div class="comment-container">
    <!-- Form -->
    <div class="comment-form-box">
      <div class="form-title">✍️ แสดงความคิดเห็น</div>

      <div class="form-row">
        <div class="form-group">
          <label class="form-label">ชื่อ / นามแฝง</label>
          <input class="form-input" id="inputName" type="text" placeholder="เช่น นักเรียน ม.3" />
        </div>
        <div class="form-group">
          <label class="form-label">ระดับชั้น</label>
          <select class="form-select" id="inputLevel">
            <option value="">-- เลือกระดับชั้น --</option>
            <option>ป.1</option><option>ป.2</option><option>ป.3</option>
            <option>ป.4</option><option>ป.5</option><option>ป.6</option>
            <option>ม.1</option><option>ม.2</option><option>ม.3</option>
            <option>ม.4</option><option>ม.5</option><option>ม.6</option>
          </select>
        </div>
      </div>

      <div class="form-group" style="margin-bottom:1rem">
        <label class="form-label">ประเภท</label>
        <div class="type-tags" id="typeTags">
          <button class="type-tag active" onclick="selectType(this, 'ความคิดเห็น')">💬 ความคิดเห็น</button>
          <button class="type-tag" onclick="selectType(this, 'ข้อเสนอแนะ')">💡 ข้อเสนอแนะ</button>
          <button class="type-tag" onclick="selectType(this, 'ร้องเรียน')">🚨 ร้องเรียน</button>
          <button class="type-tag" onclick="selectType(this, 'ขอสิ่งอำนวยความสะดวก')">🙏 ขอสิ่งอำนวยความสะดวก</button>
        </div>
      </div>

      <div class="form-group" style="margin-bottom:1rem">
        <label class="form-label">รายละเอียด</label>
        <textarea class="form-textarea" id="inputText" placeholder="พิมพ์สิ่งที่อยากบอก อยากได้ อยากให้ปรับปรุง..."></textarea>
      </div>

      <button class="btn-submit" onclick="submitComment()">📨 ส่งความคิดเห็น</button>
    </div>

    <!-- List -->
    <div class="comments-list-title">
      💌 เสียงจากนักเรียน
      <span class="comment-count-badge" id="countBadge">0</span>
    </div>
    <div id="commentsList">
      <div class="empty-state">
        <div class="icon">🌟</div>
        <p>ยังไม่มีความคิดเห็น<br/>เป็นคนแรกที่บอกเราได้เลย!</p>
      </div>
    </div>
  </div>
</div>

<!-- Toast -->
<div class="toast" id="toast">✅ ส่งความคิดเห็นแล้ว ขอบคุณมากนะ!</div>

<script>
  // Generate stars
  const container = document.getElementById('starsContainer');
  for (let i = 0; i < 60; i++) {
    const s = document.createElement('div');
    s.className = 'star';
    s.style.left = Math.random() * 100 + '%';
    s.style.top = Math.random() * 100 + '%';
    s.style.animationDelay = Math.random() * 3 + 's';
    s.style.animationDuration = (2 + Math.random() * 3) + 's';
    container.appendChild(s);
  }

  // Page nav — hide all pages, show target, scroll to very top instantly
  function goTo(id) {
    document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
    document.getElementById(id).classList.add('active');
    document.documentElement.scrollTop = 0;
    document.body.scrollTop = 0;
  }

  // ===== Comments with localStorage =====
  const STORAGE_KEY = 'sarasas_comments_v1';

  function loadComments() {
    try {
      const raw = localStorage.getItem(STORAGE_KEY);
      return raw ? JSON.parse(raw) : [];
    } catch(e) { return []; }
  }

  function saveComments() {
    try { localStorage.setItem(STORAGE_KEY, JSON.stringify(comments)); } catch(e) {}
  }

  let comments = loadComments();
  let selectedType = 'ความคิดเห็น';

  function selectType(el, type) {
    document.querySelectorAll('.type-tag').forEach(t => t.classList.remove('active'));
    el.classList.add('active');
    selectedType = type;
  }

  function submitComment() {
    const name = document.getElementById('inputName').value.trim() || 'นักเรียนนิรนาม';
    const level = document.getElementById('inputLevel').value;
    const text = document.getElementById('inputText').value.trim();

    if (!text) {
      document.getElementById('inputText').style.borderColor = 'var(--red)';
      document.getElementById('inputText').focus();
      setTimeout(() => document.getElementById('inputText').style.borderColor = '', 1500);
      return;
    }

    const avatars = ['😊','🎓','📖','🌟','🏅','✨','🎒','💫'];
    const comment = {
      id: Date.now(),
      name, level, type: selectedType, text,
      avatar: avatars[Math.floor(Math.random() * avatars.length)],
      time: new Date().toLocaleString('th-TH', { hour:'2-digit', minute:'2-digit', day:'numeric', month:'short' }),
      likes: 0,
      liked: false
    };

    comments.unshift(comment);
    saveComments();
    renderComments();

    document.getElementById('inputName').value = '';
    document.getElementById('inputText').value = '';
    document.getElementById('inputLevel').value = '';

    showToast();
  }

  function toggleLike(id) {
    const c = comments.find(x => x.id === id);
    if (!c) return;
    c.liked = !c.liked;
    c.likes += c.liked ? 1 : -1;
    saveComments();
    renderComments();
  }

  function renderComments() {
    const list = document.getElementById('commentsList');
    document.getElementById('countBadge').textContent = comments.length;

    if (comments.length === 0) {
      list.innerHTML = `<div class="empty-state"><div class="icon">🌟</div><p>ยังไม่มีความคิดเห็น<br/>เป็นคนแรกที่บอกเราได้เลย!</p></div>`;
      return;
    }

    list.innerHTML = comments.map(c => `
      <div class="comment-item">
        <div class="comment-header">
          <div class="comment-avatar">${c.avatar}</div>
          <div class="comment-meta">
            <div class="comment-author">
              ${c.name}
              ${c.level ? `<span class="comment-level-badge">${c.level}</span>` : ''}
              <span class="comment-type-pill pill-${c.type}">${c.type}</span>
            </div>
            <div class="comment-time">${c.time}</div>
          </div>
        </div>
        <div class="comment-text">${c.text.replace(/\n/g,'<br/>')}</div>
        <div class="comment-likes">
          <button class="like-btn ${c.liked ? 'liked' : ''}" onclick="toggleLike(${c.id})">
            👍 ${c.likes > 0 ? c.likes : ''} เห็นด้วย
          </button>
        </div>
      </div>
    `).join('');
  }

  function showToast() {
    const t = document.getElementById('toast');
    t.classList.add('show');
    setTimeout(() => t.classList.remove('show'), 3000);
  }

  renderComments();
</script>
</body>
</html>
